---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { schemaOrg } from '../utils/schema';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Soporte técnico de computadores a domicilio en Copacabana, Antioquia. Diagnóstico gratis, garantía escrita y factura electrónica.',
  ogImage,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <SEO title={title} description={description} ogImage={ogImage} />

    <!-- Favicon -->
    <!-- Reemplazar con favicon de marca definitivo: public/favicon.ico y public/favicon.svg -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org LocalBusiness JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>
  <body class="bg-white text-tecni-dark font-sans">
    <slot />
  </body>
</html>
