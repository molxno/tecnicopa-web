---
import { services } from '../utils/content';
import { WHATSAPP_URL } from '../utils/links';
---

<section id="servicios" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-tecni-dark mb-4">Nuestros servicios</h2>
      <p class="text-tecni-dark/60 max-w-xl mx-auto">
        Soluciones técnicas reales para los problemas más comunes. Sin tecnicismos, sin sorpresas.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        services.map((service) => (
          <article class="flex flex-col gap-3 p-6 rounded-2xl border border-tecni-lilac/40 hover:border-tecni-purple/40 hover:shadow-md transition-all">
            <span class="text-3xl" aria-hidden="true">
              {service.icon}
            </span>
            <h3 class="font-bold text-tecni-dark">{service.title}</h3>
            <p class="text-sm text-tecni-dark/60 leading-relaxed">{service.description}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-10 p-6 rounded-2xl bg-tecni-lavender">
      <p class="text-sm font-medium text-tecni-dark/70 mb-4">También ofrecemos:</p>
      <div class="flex flex-wrap gap-2">
        <span class="text-xs font-medium bg-white text-tecni-purple border border-tecni-lilac px-3 py-1.5 rounded-full">Ensamble de PCs a la medida</span>
        <span class="text-xs font-medium bg-white text-tecni-purple border border-tecni-lilac px-3 py-1.5 rounded-full">Actualización de RAM y SSD</span>
        <span class="text-xs font-medium bg-white text-tecni-purple border border-tecni-lilac px-3 py-1.5 rounded-full">Instalación de software</span>
        <span class="text-xs font-medium bg-white text-tecni-purple border border-tecni-lilac px-3 py-1.5 rounded-full">Configuración de redes WiFi</span>
        <span class="text-xs font-medium bg-white text-tecni-purple border border-tecni-lilac px-3 py-1.5 rounded-full">Asesoría en compra de equipos</span>
        <span class="text-xs font-medium bg-white text-tecni-purple border border-tecni-lilac px-3 py-1.5 rounded-full">Cotización y compra de componentes</span>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-tecni-purple text-white font-medium px-6 py-3 rounded-xl hover:bg-tecni-purple/90 transition-colors"
      >
        Agendar servicio
      </a>
    </div>
  </div>
</section>
