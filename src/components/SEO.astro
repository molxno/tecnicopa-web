---
import { resolveOgImageUrl, DEFAULT_OG_IMAGE, DEFAULT_ROBOTS } from '../utils/seo';

interface Props {
  title: string;
  description: string;
  canonicalURL?: URL | string;
  ogImage?: string;
  robots?: string;
}

const {
  title,
  description,
  canonicalURL = Astro.url,
  ogImage = DEFAULT_OG_IMAGE,
  robots = DEFAULT_ROBOTS,
} = Astro.props;

const ogImageAbsolute = resolveOgImageUrl(ogImage);
---

<!-- SEO primario -->
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:locale" content="es_CO" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:alt" content="TecniCopa — Soporte técnico en Copacabana" />
<meta property="og:site_name" content="TecniCopa" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
