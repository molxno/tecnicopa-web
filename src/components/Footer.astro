---
import { getCurrentYear } from '../utils/date';
import { NAV_LINKS } from '../utils/content';

const currentYear = getCurrentYear();
const navLinks = NAV_LINKS;
---

<footer class="bg-tecni-dark border-t border-white/10 py-10">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <a href="/" class="flex items-center gap-2">
        <img src="/logo.png" alt="TecniCopa" class="h-8 w-8 rounded-lg" loading="lazy" />
        <span class="text-white font-bold">TecniCopa</span>
      </a>

      <nav aria-label="Navegación del pie de página">
        <ul class="flex flex-wrap justify-center gap-4">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/50 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <a
        href="https://instagram.com/tecnicopa"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-white/50 hover:text-white transition-colors"
        aria-label="Ir al Instagram de TecniCopa"
      >
        @tecnicopa
      </a>
    </div>

    <div class="mt-8 pt-6 border-t border-white/10 text-center">
      <p class="text-xs text-white/30">
        &copy; {currentYear} TecniCopa. Todos los derechos reservados. Copacabana, Antioquia, Colombia.
      </p>
    </div>
  </div>
</footer>
